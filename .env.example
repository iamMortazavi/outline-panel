# Most settings (servers, bot token, admin IDs, password, 2FA) are managed from
# the panel UI and stored in the database. This file only holds bootstrap and
# runtime values.

# ===== Web dashboard =====
# Initial panel password (seeds the DB on first run; change it later in the panel).
ADMIN_PASSWORD=change-me-to-a-strong-password
# Fixed secret so sessions survive restarts. REQUIRED in production / multi-worker.
# Generate with: python -c "import secrets;print(secrets.token_hex(32))"
SESSION_SECRET=
# Send the session cookie only over HTTPS. Default true; set false for local HTTP.
COOKIE_SECURE=true
# (optional) session lifetime in seconds (default 7 days)
SESSION_MAX_AGE=604800
# (optional) bind address for `outline-panel`
HOST=0.0.0.0
PORT=8000

# ===== Storage / scheduler =====
DB_PATH=outline_bot.db
# (optional) seconds between expiry/notification checks
EXPIRY_CHECK_INTERVAL=60
# Run the background scheduler in the web app. Set "false" on the web app when a
# standalone bot (sharing the same DB) already runs it.
ENABLE_SCHEDULER=true

# ===== Optional first-run bootstrap =====
# Import one Outline server on first run (otherwise add servers from the UI).
OUTLINE_API_URL=
# certSha256 from the Outline config — pins the server's TLS cert (prevents MITM).
OUTLINE_CERT_SHA256=
# Seed the Telegram bot on first run (otherwise configure it in the panel).
BOT_TOKEN=
# Numeric admin IDs, comma separated. Send /id to the bot to find yours.
ADMIN_IDS=
# Admin alert thresholds.
NOTIFY_LIMIT_PERCENT=80
NOTIFY_EXPIRY_DAYS=3
