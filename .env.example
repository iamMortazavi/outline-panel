# Most settings (servers, bot token, admin IDs, password, 2FA) are managed from
# the panel UI and stored in the database. This file only holds bootstrap and
# runtime values.

# ===== Web dashboard =====
# Initial panel password (seeds the DB on first run; change it later in the panel).
ADMIN_PASSWORD=change-me-to-a-strong-password
# Fixed secret so sessions survive restarts. REQUIRED in production / multi-worker.
# Generate with: python -c "import secrets;print(secrets.token_hex(32))"
SESSION_SECRET=
# Session cookie Secure flag: "auto" (default) marks it Secure only when the
# request is HTTPS — so the panel works over http://IP:8000 and stays secure
# behind an HTTPS reverse proxy. Force with "true"/"false" if you need to.
COOKIE_SECURE=auto
# Trust X-Forwarded-For / X-Forwarded-Proto. Set "true" ONLY when the panel is
# behind a reverse proxy you control (e.g. Caddy/Nginx) — it is required there so
# the login rate-limit sees real client IPs and the cookie Secure flag works.
# Keep "false" (default) for direct http://IP:8000 access, where these headers
# are attacker-controlled.
TRUST_PROXY=false
# (optional) session lifetime in seconds (default 7 days)
SESSION_MAX_AGE=604800
# (optional) bind address for `outline-panel`
HOST=0.0.0.0
PORT=8000

# ===== Storage / scheduler =====
DB_PATH=outline_bot.db
# (optional) seconds between expiry/notification checks
EXPIRY_CHECK_INTERVAL=60
# Run the background scheduler in the web app. Set "false" on the web app when a
# standalone bot (sharing the same DB) already runs it.
ENABLE_SCHEDULER=true

# ===== Optional first-run bootstrap =====
# Import one Outline server on first run (otherwise add servers from the UI).
OUTLINE_API_URL=
# certSha256 from the Outline config — pins the server's TLS cert (prevents MITM).
OUTLINE_CERT_SHA256=
# Seed the Telegram bot on first run (otherwise configure it in the panel).
BOT_TOKEN=
# Numeric admin IDs, comma separated. Send /id to the bot to find yours.
ADMIN_IDS=
# Public HTTPS base URL of the panel — enables the Telegram Mini App (Web App),
# served at <base>/tma and opened from the bot. Must be HTTPS. Can also be set
# from the panel's bot settings. Example: https://panel.example.com
WEBAPP_URL=
# Admin alert thresholds.
NOTIFY_LIMIT_PERCENT=80
NOTIFY_EXPIRY_DAYS=3
