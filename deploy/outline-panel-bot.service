[Unit]
Description=Outline Panel (Telegram bot)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
# adjust User and paths to your setup
User=outline
WorkingDirectory=/opt/outline-panel
EnvironmentFile=/opt/outline-panel/.env
ExecStart=/opt/outline-panel/.venv/bin/outline-panel-bot
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
